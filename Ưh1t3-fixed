-- ---------- OnDamagePlayer callback: nhận player (server) và set GameStats an toàn ----------
entity:SetCallback("OnDamagePlayer", function(player, newHealth)
    -- player có thể là Player instance — kiểm tra an toàn
    if typeof(player) ~= "Instance" or not player:IsA("Player") then return end

    pcall(function()
        local ReSt = game:GetService("ReplicatedStorage")
        if ReSt and ReSt:FindFirstChild("GameStats") then
            local stats = ReSt.GameStats:FindFirstChild("Player_"..player.Name)
            if stats and stats:FindFirstChild("Total") and stats.Total:FindFirstChild("DeathCause") then
                stats.Total.DeathCause.Value = "wh1t3"
            end
        end
    end)
end)

-- ---------- chạy entity ----------
