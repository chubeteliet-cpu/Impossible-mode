-- Server script: đặt trong ServerScriptService hoặc Workspace (dùng executor có isfile/writefile/getcustomasset)
local RunService = game:GetService("RunService")
if not RunService:IsServer() then
    warn("Chạy trên client? Script này nên chạy server-side.")
end

local spawner = loadstring(game:HttpGet("https://raw.githubusercontent.com/RegularVynixu/Utilities/main/Doors/Entity%20Spawner/V2/Source.lua"))()

-- ---------- helper để tạo / lấy main color correction nếu chưa có ----------
local Lighting = game:GetService("Lighting")
local function ensureMainColorCorrection()
    local cc = Lighting:FindFirstChild("MainColorCorrection")
    if not cc then
        cc = Instance.new("ColorCorrectionEffect")
        cc.Name = "MainColorCorrection"
        cc.Parent = Lighting
    end
    return cc
end

local cc = ensureMainColorCorrection()

-- ---------- hàm tải mp3 từ GitHub (dành cho exploit environment) ----------
local function getGitSoundId(url, name)
    -- pcall để an toàn nếu môi trường không hỗ trợ writefile/getcustomasset
    local ok, res = pcall(function()
        if not isfile(name..".mp3") then
            writefile(name..".mp3", game:HttpGet(url))
        end
        return getcustomasset(name..".mp3")
    end)
    if ok and res then
        return res
    else
        warn("Không thể tải/convert sound từ URL: "..tostring(url).." (fallback nil). Lỗi: "..tostring(res))
        return nil
    end
end

local SOUND_URL = "https://raw.githubusercontent.com/chubeteliet-cpu/Mode-music/main/Wh1t3.mp3"

-- ---------- tạo và phát sound (global) ----------
local sound = Instance.new("Sound")
sound.Name = "GlobalOneShot"
local loadedId = getGitSoundId(SOUND_URL, "wh1t3_music")
if loadedId then
    sound.SoundId = loadedId
else
    -- nếu không tải được, bỏ qua phát thay vì crash
    warn("Sound không được phát vì không tải được file.")
end
sound.Volume = 4
sound.Looped = false
sound.PlaybackSpeed = 1
sound.RollOffMode = Enum.RollOffMode.InverseTapered
sound.Parent = workspace

if sound.SoundId and sound.SoundId ~= "" then
    pcall(function() sound:Play() end)
    sound.Ended:Connect(function()
        if sound and sound.Parent then sound:Destroy() end
    end)
end

-- ---------- lighting effects (an toàn nếu thiếu cc) ----------
